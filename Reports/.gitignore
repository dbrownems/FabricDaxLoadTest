# Power BI Desktop per-developer cache & local-only state.
# These live next to .pbip/.SemanticModel/.Report folders and contain
# session caches, last-opened state, credentials hashes, and data caches.
.pbi/
cache.abf
**/cache.abf
*.pbix
*.pbids

# Local parameter overrides (Option B / Option C side files). Real SQL
# endpoint hostnames and database names go here, never in expressions.tmdl.
**/expressions.tmdl.local
