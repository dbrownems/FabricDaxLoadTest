	partition QueryExecutions = m
		mode: directQuery
		source =
				let
				    Source = Sql.Database(ServerName, DatabaseName),
				    Data = Source{[Schema=SchemaName, Item="QueryExecutions"]}[Data]
				in
				    Data

	annotation PBI_ResultType = Table
