table QueryExecutions
	lineageTag: 44807d1c-9eb5-4e9d-abd2-8a552e53cdcd

	/// Number of query executions in the current filter context.
	measure 'Total Executions' = COUNTROWS(QueryExecutions)
		formatString: #,0
		lineageTag: 085415fa-28be-4825-8146-a5607f6576e6

	measure 'Successful Executions' = CALCULATE([Total Executions], QueryExecutions[Outcome] = "Success")
		formatString: #,0
		lineageTag: 1835a92e-c06e-4ba6-a5d4-79a462736891

	measure 'Failed Executions' = CALCULATE([Total Executions], QueryExecutions[Outcome] = "Error")
		formatString: #,0
		lineageTag: 6d8e1a86-d187-4893-97cc-94f2470fa9b7

	/// Queries per second — successful executions divided by run duration. Within a single run this matches the headline QPS reported by the load generator.
	measure QPS = DIVIDE([Successful Executions], MAX(LoadTestRuns[DurationSec]))
		formatString: 0.0
		lineageTag: d361b3d5-6d38-478c-9f71-c3b31f4ef3a6

	/// Mean client-observed query duration in milliseconds.
	measure 'Avg Latency (ms)' = AVERAGE(QueryExecutions[ClientDurationMs])
		formatString: #,0
		lineageTag: 0ea1f035-87da-48d5-98f2-ba785052e43c

	measure 'Max Latency (ms)' = MAX(QueryExecutions[ClientDurationMs])
		formatString: #,0
		lineageTag: 467db6b0-348a-4028-af97-7f841e4c65d2

	measure 'P50 Latency (ms)' = PERCENTILEX.INC(QueryExecutions, QueryExecutions[ClientDurationMs], 0.5)
		formatString: #,0
		lineageTag: 3cfae3e2-4c8d-488f-aa40-79927a30a46e

	measure 'P95 Latency (ms)' = PERCENTILEX.INC(QueryExecutions, QueryExecutions[ClientDurationMs], 0.95)
		formatString: #,0
		lineageTag: 576a3f1e-a664-4201-acbf-f3f89741d657

	measure 'P99 Latency (ms)' = PERCENTILEX.INC(QueryExecutions, QueryExecutions[ClientDurationMs], 0.99)
		formatString: #,0
		lineageTag: 914e1f9c-4c0a-4fbf-9469-4e46dbc5b76e

	/// Total engine CPU consumed, in CPU-seconds. Sum of ExecutionMetrics.totalCpuTimeMs across executions.
	measure 'Engine CPU (s)' = DIVIDE(SUM(QueryExecutions[EngineCpuMs]), 1000)
		formatString: 0.00
		lineageTag: 6b1db459-8e5a-4d8d-b333-0a9ed9d6ac65

	measure 'SE CPU (s)' = DIVIDE(SUM(QueryExecutions[SECpuMs]), 1000)
		formatString: 0.00
		lineageTag: 84f746ff-4ad9-4973-8d51-a1e85ac28b64

	measure 'FE CPU (s)' = DIVIDE(SUM(QueryExecutions[FECpuMs]), 1000)
		formatString: 0.00
		lineageTag: 831e1dbb-a89d-4275-a968-95c97bada0ea

	measure 'Engine Duration (s)' = DIVIDE(SUM(QueryExecutions[EngineDurationMs]), 1000)
		formatString: 0.00
		lineageTag: 4242d79e-269b-47b7-94a2-9a8e4028982a

	/// Total engine CPU in milliseconds. Used as the ranking measure for the Top Queries by CPU visual.
	measure 'Total Engine CPU (ms)' = SUM(QueryExecutions[EngineCpuMs])
		formatString: #,0
		lineageTag: 82947d8f-c861-4f16-b24d-f700909e16ab

	/// Peak concurrent virtual users seen at any point in the current filter context.
	measure 'Active Users (max)' = MAX(QueryExecutions[ActiveUsersAtStart])
		formatString: #,0
		lineageTag: 016ca1de-f0fc-49e4-b5f9-9e26cbe226a1

	/// Total capacity-router throttling time, in seconds. Sum of ExecutionMetrics.capacityThrottlingMs across executions. >0 indicates the capacity SKU was throttling.
	measure 'Throttling (s)' = DIVIDE(SUM(QueryExecutions[CapacityThrottlingMs]), 1000)
		formatString: 0.00
		lineageTag: 8a4c1d72-1a3e-4e7b-a2cb-7f4e6b9c1d22

	measure 'Throttled Executions' = CALCULATE([Total Executions], QueryExecutions[CapacityThrottlingMs] > 0)
		formatString: #,0
		lineageTag: c14a92d5-2d8b-4f1a-9b0a-6d3a8e4f1c33

	/// Fraction of executions that were capacity-router throttled.
	measure '% Throttled' = DIVIDE([Throttled Executions], [Total Executions])
		formatString: 0.0%
		lineageTag: 9b1e7c38-3f4d-45a2-bb71-1f2a9d0e7c44


