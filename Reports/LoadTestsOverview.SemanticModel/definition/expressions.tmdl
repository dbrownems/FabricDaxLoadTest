/// SQL endpoint hostname of the Fabric Lakehouse, e.g.
/// "x6eps4xrq2xudenlfv6naeo3i4-olzonbjxjeyu5ez2pyhhh5obe4.msit-datawarehouse.fabric.microsoft.com".
/// Get this from your lakehouse's Settings -> SQL analytics endpoint.
expression ServerName =
		"REPLACE-WITH-YOUR-SQL-ENDPOINT.datawarehouse.fabric.microsoft.com" meta [IsParameterQuery = true, IsParameterQueryRequired = true, Type = "Text"]
	lineageTag: 8fc8295e-c61e-4491-9f26-0d4ec90810e7

	annotation PBI_ResultType = Text

/// Lakehouse (database) name as it appears in the SQL endpoint, e.g. "LoadTests".
expression DatabaseName =
		"LoadTests" meta [IsParameterQuery = true, IsParameterQueryRequired = true, Type = "Text"]
	lineageTag: 8a96f4d4-43c6-4c46-b655-3308e165b086

	annotation PBI_ResultType = Text

/// SQL schema where the load-test tables live. Use "dbo" for non-schema-enabled
/// lakehouses (the Fabric default) or for schema-enabled lakehouses where the
/// fdlt_runtime writer wrote to dbo. Set to a different schema (e.g. "loadtest")
/// if you customised LakehouseInfo.schema.
expression SchemaName =
		"dbo" meta [IsParameterQuery = true, IsParameterQueryRequired = true, Type = "Text"]
	lineageTag: 62e81f10-d2c1-4c3c-8702-a7ce144fa2ce

	annotation PBI_ResultType = Text
